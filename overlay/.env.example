# Required: private key for overlay node identity (64-char hex)
OVERLAY_PRIVATE_KEY=your_private_key_hex_here

# Required: MongoDB connection string
MONGODB_URI=mongodb://localhost:27017

# Optional: public URL where this overlay is reachable
OVERLAY_HOSTING_URL=http://localhost:8081

# Optional: port (default 8081)
OVERLAY_PORT=8081

# Optional: external database for engine state (default: SQLite ./data/overlay.db)
# KNEX_URL=postgresql://user:pass@host/db
